# ============================================================
# Sandbox-only secrets and machine-local state
# ============================================================

# SSH keys used by sandbox agents to push to Gitee.
# These are per-machine state, MUST NEVER enter the repo.
# (Sandbox stores them under <repo>/.ssh/ so they survive container restart,
#  but they are not part of the project — never commit.)
.ssh/

# Per-sandbox scratch / cache / tools
.version/
NOTES.md
scratch/
*.tmp

# Plan engine runtime state (board.md, outputs/, etc.) — only the curated
# .plan files (static, hand-written) are part of the project.
.mavis/plans/plan-*.yaml
.mavis/plans/requirement-analysis-plan.yaml
.mavis/plans/*/board.md
.mavis/plans/*/outputs/

# TypeScript build info
*.tsbuildinfo

# Backup files
*.bak
*.v2-selfdev.bak
