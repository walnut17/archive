# ============================================================
# Sandbox-only secrets and machine-local state
# ============================================================

# SSH keys used by sandbox agents to push to Gitee.
# These are per-machine state, MUST NEVER enter the repo.
# (Sandbox stores them under <repo>/.ssh/ so they survive container restart,
#  but they are not part of the project — never commit.)
.ssh/

# Per-sandbox scratch / cache / tools
# - .version/, scratch/ 是沙箱临时文件，不进仓库
# - backend/tools/ 是沙箱离线工具集（JDK + Maven 大二进制），
#   但 mvn-tools.sh / README.md 这些小文档可以 commit
#   （JDK/Maven 大二进制由接手 agent 在自己沙箱装，按 README §Step 2/3）
.version/
NOTES.md
scratch/
*.tmp
# mvn / 构建测试原始日志 → test-to-settle/logs/（见 test-to-settle/logs/README.md）
test-to-settle/logs/*
!test-to-settle/logs/README.md
mvn-*.log
backend/tools/jdk17/
backend/tools/apache-maven-3.9.9/
backend/tools/certs/
backend/tools/*.deb
backend/tools/*.tar.gz
# ! 显式允许: mvn-tools.sh 和 README.md 即使在 tools/ 下也进仓库
!backend/tools/mvn-tools.sh
!backend/tools/README.md

# Plan engine runtime state (board.md, outputs/, etc.) — only the curated
# .plan files (static, hand-written) are part of the project.
.mavis/plans/plan-*.yaml
.mavis/plans/requirement-analysis-plan.yaml
.mavis/plans/*/board.md
.mavis/plans/*/outputs/

# TypeScript build info
*.tsbuildinfo

# Vue components.d.ts (generated by unplugin-vue-components)
frontend/components.d.ts
frontend/auto-imports.d.ts

# Backup files
*.bak
*.v2-selfdev.bak
