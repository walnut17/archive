<?xml version="1.0" encoding="UTF-8"?>
<!--
  WinSW 配置 — Python qa-agent 微服务
  125 约定：代码 D:\projects-online\qa-agent · 配置/数据 D:\archive\*
  安装: 复制本文件 + qa-agent-service.exe 到 D:\projects-online\qa-agent，再 qa-agent-service.exe install
  启停: net start/stop qa-agent
-->
<service>
  <id>qa-agent</id>
  <name>qa-agent (投委会档案 QA 微服务)</name>
  <description>Python FastAPI 智能问答微服务，由 Java BFF 转发调用</description>

  <executable>D:\projects-online\qa-agent\.venv\Scripts\python.exe</executable>
  <arguments>-m uvicorn app.main:app --host 0.0.0.0 --port 8001 --log-level info</arguments>

  <workingdirectory>D:\projects-online\qa-agent</workingdirectory>

  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="1 min"/>
  <resetsfailure after="1 hour"/>

  <logpath>D:\archive\logs\qa-agent</logpath>
  <log mode="roll">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>10</keepFiles>
  </log>

  <!-- 与 backend 共用 config.json；storage.* 指向 D:/archive/files 等 -->
  <env name="CONFIG_JSON_PATH" value="D:\archive\config\config.json"/>
</service>
